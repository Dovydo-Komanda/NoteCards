<Window x:Class="NoteCards.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NoteCards.Controls"
        xmlns:vm="clr-namespace:NoteCards.ViewModels"
        Title="NoteCards" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#EBEBEF">
    <Window.Resources>
        <Style x:Key="PopupMenuButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#1C1C1C"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="PopupItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PopupItemBorder" Property="Background" Value="#F0F0F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PopupItemBorder" Property="Background" Value="#E4E4EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0"
                Background="#F3F3F3"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <TextBlock Text="NoteCards"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#1C1C1C"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Button Content="+ Pridėti užrašą"
                            Padding="14,6"
                            FontSize="13"
                            Command="{Binding AddNoteCommand}"
                            Cursor="Hand"
                            Margin="0,0,8,0"/>
                    <Button x:Name="HamburgerButton"
                            Content="☰"
                            Padding="12,6"
                            FontSize="16"
                            Cursor="Hand"
                            ToolTip="Meniu"
                            Click="HamburgerButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Hamburger Popup Menu -->
        <Popup x:Name="HamburgerPopup"
               Grid.Row="0"
               PlacementTarget="{Binding ElementName=HamburgerButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
            <Border Background="White"
                    BorderBrush="#D8D8D8"
                    BorderThickness="1"
                    CornerRadius="8"
                    MinWidth="190"
                    Padding="4"
                    Margin="12,10,12,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <Button Style="{StaticResource PopupMenuButtonStyle}"
                            IsEnabled="False">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" Width="20" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Nustatymai" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Margin="8,1"/>
                    <Button Style="{StaticResource PopupMenuButtonStyle}"
                            Click="AboutButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ℹ" Width="20" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Apie programą" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Dashboard -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      Padding="8">
            <ItemsControl ItemsSource="{Binding Notes}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:NoteCardViewModel}">
                        <controls:NoteCardControl/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
