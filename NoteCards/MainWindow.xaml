<Window x:Class="NoteCards.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NoteCards.Controls"
        xmlns:vm="clr-namespace:NoteCards.ViewModels"
        xmlns:Views="clr-namespace:NoteCards.Views"
        Title="NoteCards" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">
    <Window.Resources>
        <Style x:Key="PopupMenuButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#1C1C1C"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="PopupItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PopupItemBorder" Property="Background" Value="#F0F0F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PopupItemBorder" Property="Background" Value="#E4E4EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FabStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Foreground" Value="#1C1C1C"/>
            <Setter Property="Background" Value="#F0F0F2"/>
            <Setter Property="BorderBrush" Value="#D0D0D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="FabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.20"
                                                  BlurRadius="16" ShadowDepth="3"
                                                  Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="0,-5,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FabBorder" Property="Background" Value="#E4E4E8"/>
                                <Setter TargetName="FabBorder" Property="BorderBrush" Value="#C2C2CA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FabBorder" Property="Background" Value="#D6D6DC"/>
                                <Setter TargetName="FabBorder" Property="BorderBrush" Value="#B4B4BE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    <Grid>

        <Grid.ColumnDefinitions>
        <ColumnDefinition Width="{Binding SidebarWidth}"/>
        <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0"  Padding="10">
            <StackPanel>
                <!-- Collapse button -->
                <Button Content="☰" Command="{Binding ToggleSidebarCommand}"/>
                <Button Content="➕ Add Note" Command="{Binding AddNoteCommand}"/>
                <Button Content="ℹ About the program" Click="AboutButton_Click"/>
                <Button Content="Functionality" Margin="0,4"/>
                <Button Content="ckat" Margin="0,4"/>
            </StackPanel>
        </Border>


    <Grid Grid.Column="1">

    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0"
                Background="{DynamicResource SidebarBackground}"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">

                        <Image Source="Assets/logo.png"
                               Width="28"
                               Height="28"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>

                        <TextBlock Text="NoteCards"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   VerticalAlignment="Center"/>

                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                        <Button Content="+ Pridėti užrašą"
                                Padding="14,6"
                                FontSize="13"
                                Command="{Binding AddNoteCommand}"
                                Cursor="Hand"
                                Margin="0,0,8,0"/>
                        <Button x:Name="HamburgerButton"
                                Content="☰"
                                Padding="12,6"
                                FontSize="16"
                                Cursor="Hand"
                                ToolTip="Meniu"
                                Click="HamburgerButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Hamburger Popup Menu -->
        <Popup x:Name="HamburgerPopup"
               Grid.Row="0"
               PlacementTarget="{Binding ElementName=HamburgerButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade">
                <Border Background="{DynamicResource SidebarBackground}"
                    BorderBrush="#D8D8D8"
                    BorderThickness="1"
                    CornerRadius="8"
                    MinWidth="190"
                    Padding="4"
                    Margin="12,10,12,14">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" ShadowDepth="1" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <Button Style="{StaticResource PopupMenuButtonStyle}"
                            Click="SettingsMenuButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="⚙" Width="20" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Nustatymai" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Separator Margin="8,1"/>
                    <Button Style="{StaticResource PopupMenuButtonStyle}"
                            Click="AboutButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="ℹ" Width="20" TextAlignment="Center" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Apie programą" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>

        <!-- Dashboard + FAB overlay -->
        <Grid Grid.Row="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="8">
                <ItemsControl ItemsSource="{Binding Notes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NoteCardViewModel}">
                            <controls:NoteCardControl/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Floating Action Button -->
            <Button Style="{StaticResource FabStyle}"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Right"
                    Margin="0,0,28,24"
                    Content="+"
                    ToolTip="Pridėti užrašą"
                    Command="{Binding AddNoteCommand}"/>

            <!-- Settings Panel Overlay -->
            <Views:SettingsPanel x:Name="SettingsPanelControl"
                                x:FieldModifier="public"
                                Visibility="Collapsed"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Panel.ZIndex="100"/>
        </Grid>
    </Grid>
    </Grid>
</Window>
