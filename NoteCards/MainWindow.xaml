<Window x:Class="NoteCards.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:NoteCards.Controls"
        xmlns:vm="clr-namespace:NoteCards.ViewModels"
        xmlns:Views="clr-namespace:NoteCards.Views"
        xmlns:converters="clr-namespace:NoteCards.Converters"
        Title="NoteCards" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackground}">
    <Window.Resources>

		<Style x:Key="RecentNoteCardStyle" TargetType="Button">
			<Setter Property="OverridesDefaultStyle" Value="True"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Background" Value="{DynamicResource CardBackground}"/>
			<Setter Property="Padding" Value="12,10"/>
			<Setter Property="Margin" Value="0,0,8,0"/>
			<Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border x:Name="CardBorder"
								Background="{TemplateBinding Background}"
								BorderBrush="{DynamicResource BorderColor}"
								BorderThickness="1"
								CornerRadius="8"
								Padding="{TemplateBinding Padding}">
							<Border.Effect>
								<DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08"/>
							</Border.Effect>
							<ContentPresenter/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter TargetName="CardBorder" Property="Background" Value="#F5F5F8"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter TargetName="CardBorder" Property="Background" Value="#EAEAEF"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
		
		
        <converters:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter" />
        <Style x:Key="PopupMenuButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#1C1C1C"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="PopupItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}"
                                Margin="2">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PopupItemBorder" Property="Background" Value="#F0F0F4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="PopupItemBorder" Property="Background" Value="#E4E4EA"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FabStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="Foreground" Value="#1C1C1C"/>
            <Setter Property="Background" Value="#F0F0F2"/>
            <Setter Property="BorderBrush" Value="#D0D0D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="FabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.20"
                                                  BlurRadius="16" ShadowDepth="3"
                                                  Direction="270"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="0,-5,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="FabBorder" Property="Background" Value="#E4E4E8"/>
                                <Setter TargetName="FabBorder" Property="BorderBrush" Value="#C2C2CA"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="FabBorder" Property="Background" Value="#D6D6DC"/>
                                <Setter TargetName="FabBorder" Property="BorderBrush" Value="#B4B4BE"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

		<Style x:Key="GroupCardStyle" TargetType="Border">
			<Setter Property="Opacity" Value="0"/>
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
			<Setter Property="RenderTransform">
				<Setter.Value>
					<TranslateTransform Y="10"/>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<EventTrigger RoutedEvent="Loaded">
					<BeginStoryboard>
						<Storyboard>
							<DoubleAnimation Storyboard.TargetProperty="Opacity"
											 To="1"
											 Duration="0:0:0.25"/>
							<DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
											 To="0"
											 Duration="0:0:0.25">
								<DoubleAnimation.EasingFunction>
									<CubicEase EasingMode="EaseOut"/>
								</DoubleAnimation.EasingFunction>
							</DoubleAnimation>
						</Storyboard>
					</BeginStoryboard>
				</EventTrigger>
			</Style.Triggers>
		</Style>
    </Window.Resources>
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
	<Grid>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="{Binding SidebarWidth}"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<!-- Sidebar -->
		<Border Grid.Column="0" Background="{DynamicResource SidebarBackground}" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0"  Padding="10">
			<StackPanel>
				<!-- Collapse button -->
				<Button Content="☰" Command="{Binding ToggleSidebarCommand}"/>
                <Button Content="{Binding [AddNote], Source={StaticResource Loc}, StringFormat=➕ {0}}" Command="{Binding AddNoteCommand}"/>
				<Button Content="{Binding [About], Source={StaticResource Loc}, StringFormat=ℹ {0}}" Click="AboutButton_Click"/>
			</StackPanel>
		</Border>


		<Grid Grid.Column="1">

			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<!-- Top Bar -->
			<Border Grid.Row="0"
					Background="{DynamicResource SidebarBackground}"
					BorderBrush="#E0E0E0"
					BorderThickness="0,0,0,1"
					Padding="16,10">
				<Grid>
					<StackPanel Orientation="Horizontal" VerticalAlignment="Center">

						<Image Source="Assets/logo.png"
                               Width="28"
                               Height="28"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>

						<TextBlock Text="NoteCards"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   VerticalAlignment="Center"/>

					</StackPanel>
                    <Grid HorizontalAlignment="Right"
						  VerticalAlignment="Center">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>

						<Border x:Name="TopSearchPanel"
								Grid.Column="0"
								Width="0"
								Height="34"
								Margin="0,0,8,0"
								Padding="10,0"
								Visibility="Collapsed"
								Background="#F5F7FB"
								BorderBrush="#DDE4F3"
								BorderThickness="1"
								CornerRadius="8"
								Opacity="0">
							<DockPanel LastChildFill="True">
                              <TextBlock Text="🔎"
										   Foreground="#74809A"
										   Margin="0,0,8,0"
                                        VerticalAlignment="Center"
										   FontSize="13"/>
								<TextBox x:Name="TopSearchTextBox"
										 BorderThickness="0"
										 Background="Transparent"
										 Foreground="{DynamicResource TextColor}"
										 VerticalContentAlignment="Center"
										 Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
										 ToolTip="{Binding [SearchNotesHint], Source={StaticResource Loc}}"
										 KeyDown="TopSearchTextBox_KeyDown"/>
							</DockPanel>
						</Border>

						<Button x:Name="TopSearchButton"
								Grid.Column="1"
                              Content="🔎"
								Width="34"
								Height="32"
								Padding="0"
                               FontSize="14"
								Cursor="Hand"
								Margin="0,0,8,0"
								ToolTip="{Binding [Search], Source={StaticResource Loc}}"
								Click="TopSearchButton_Click"/>

						<Button x:Name="TagsFilterButton"
								Grid.Column="2"
                              Content="🏷"
								Width="34"
								Height="32"
								Padding="0"
                               FontSize="14"
								Cursor="Hand"
								Margin="0,0,8,0"
								ToolTip="{Binding TagFilterButtonText}"
								Click="TagsFilterButton_Click"/>

						<Button x:Name="HamburgerButton"
								Grid.Column="3"
								Content="☰"
								Padding="12,6"
								FontSize="16"
								Cursor="Hand"
								ToolTip="{Binding [Menu], Source={StaticResource Loc}}"
								Click="HamburgerButton_Click"/>
					</Grid>
				</Grid>
			</Border>

			<Popup x:Name="TagsFilterPopup"
				   Grid.Row="0"
				   PlacementTarget="{Binding ElementName=TagsFilterButton}"
				   Placement="Bottom"
				   StaysOpen="False"
				   AllowsTransparency="True"
				   PopupAnimation="Fade">
				<Border Background="{DynamicResource SidebarBackground}"
						BorderBrush="#D8D8D8"
						BorderThickness="1"
						CornerRadius="10"
						MinWidth="260"
						MaxWidth="320"
						Padding="8"
						Margin="12,10,12,14">
					<Border.Effect>
						<DropShadowEffect Color="#000000" Opacity="0.14" BlurRadius="14" ShadowDepth="1" Direction="270"/>
					</Border.Effect>
					<StackPanel>
						<Grid Margin="4,2,4,8">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<TextBlock Text="{Binding [FilterTags], Source={StaticResource Loc}}"
									   FontWeight="SemiBold"
									   Foreground="{DynamicResource TextColor}"
									   VerticalAlignment="Center"/>
							<Button Grid.Column="1"
									Style="{StaticResource PopupMenuButtonStyle}"
									Padding="8,4"
									Content="{Binding [ClearFilters], Source={StaticResource Loc}}"
									Command="{Binding ClearTagFiltersCommand}"/>
						</Grid>
						<Border Background="#F5F6FB"
								CornerRadius="8"
								Padding="10,14"
								Visibility="{Binding HasTagFilters, Converter={StaticResource BoolToVis}}">
							<ScrollViewer MaxHeight="230" VerticalScrollBarVisibility="Auto">
								<ItemsControl ItemsSource="{Binding TagFilters}">
									<ItemsControl.ItemTemplate>
										<DataTemplate DataType="{x:Type vm:TagFilterItemViewModel}">
											<CheckBox Content="{Binding Tag}"
													  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
													  Margin="0,2"
													  Foreground="{DynamicResource TextColor}"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</ScrollViewer>
						</Border>
                      <TextBlock Text="{Binding [NoTagsFound], Source={StaticResource Loc}}"
								   Margin="4,8,4,6"
								   FontStyle="Italic"
								   Foreground="#7A7F90">
							<TextBlock.Style>
								<Style TargetType="TextBlock">
									<Setter Property="Visibility" Value="Collapsed"/>
									<Style.Triggers>
										<DataTrigger Binding="{Binding HasTagFilters}" Value="False">
											<Setter Property="Visibility" Value="Visible"/>
										</DataTrigger>
									</Style.Triggers>
								</Style>
							</TextBlock.Style>
						</TextBlock>
					</StackPanel>
				</Border>
			</Popup>

			<!-- Hamburger Popup Menu -->
            <Popup x:Name="HamburgerPopup"
				   Grid.Row="0"
				   PlacementTarget="{Binding ElementName=HamburgerButton}"
				   Placement="Bottom"
				   StaysOpen="False"
				   AllowsTransparency="True"
				   PopupAnimation="Fade">
                <Border Background="{DynamicResource SidebarBackground}"
                    BorderBrush="#D8D8D8"
                    BorderThickness="1"
                    CornerRadius="8"
                    MinWidth="190"
                    Padding="4"
                    Margin="12,10,12,14">
                    <Border.Effect>
                        <DropShadowEffect Color="#000000" Opacity="0.12" BlurRadius="12" ShadowDepth="1" Direction="270"/>
                    </Border.Effect>
                    <StackPanel>
                        <Button Style="{StaticResource PopupMenuButtonStyle}"
								Click="SettingsMenuButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="⚙" Width="20" TextAlignment="Center" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource TextColor}"/>
                                 <TextBlock Text="{Binding [Settings], Source={StaticResource Loc}}"
                                           FontSize="14"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>
                        </Button>
                        <!-- 'Open From File' moved to Note editor -->
                        <Separator Margin="8,1"/>
                        <Button Style="{StaticResource PopupMenuButtonStyle}"
                                Click="AboutButton_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="ℹ" Width="20" TextAlignment="Center" FontSize="14" VerticalAlignment="Center" Foreground="{DynamicResource TextColor}"/>
                                 <TextBlock Text="{Binding [About], Source={StaticResource Loc}}" FontSize="14" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

			<!-- Dashboard + FAB overlay -->
			<Grid Grid.Row="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
				</Grid.RowDefinitions>
				<!-- Recent Notes strip -->
				<Border Grid.Row="0"
						Background="{DynamicResource SidebarBackground}"
						BorderBrush="{DynamicResource BorderColor}"
						BorderThickness="0,0,0,1"
						Padding="16,12">
                    <StackPanel>
						<Grid>
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							<TextBlock Text="{Binding [RecentNotes], Source={StaticResource Loc}}"
									   FontSize="13"
									   FontWeight="SemiBold"
									   Foreground="{DynamicResource TextColor}"
									   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"
									   VerticalAlignment="Center"/>
							<Button Grid.Column="1"
									Width="28"
									Height="28"
									Padding="0"
									FontSize="15"
									Background="Transparent"
									BorderThickness="0"
									Cursor="Hand"
                                 ToolTip="Show/Hide recent notes"
									Click="ToggleRecentSectionButton_Click">
								<Button.Style>
									<Style TargetType="Button">
										<Setter Property="Content" Value="▾"/>
										<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
										<Setter Property="RenderTransform">
											<Setter.Value>
												<RotateTransform Angle="0"/>
											</Setter.Value>
										</Setter>
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsRecentSectionExpanded}" Value="False">
												<Setter Property="RenderTransform">
													<Setter.Value>
														<RotateTransform Angle="-90"/>
													</Setter.Value>
												</Setter>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Button.Style>
							</Button>
						</Grid>
                      <Border x:Name="RecentSectionBody"
								Margin="0,10,0,0"
								RenderTransformOrigin="0.5,0">
							<Border.RenderTransform>
								<TranslateTransform/>
							</Border.RenderTransform>
							<ScrollViewer x:Name="RecentNotesScrollViewer"
										  HorizontalScrollBarVisibility="Auto"
										  VerticalScrollBarVisibility="Disabled"
										  CanContentScroll="True"
										  PanningMode="HorizontalOnly"
										  PreviewMouseWheel="RecentNotesScrollViewer_PreviewMouseWheel">
								<ItemsControl ItemsSource="{Binding RecentNotes}">
									<ItemsControl.ItemsPanel>
										<ItemsPanelTemplate>
											<StackPanel Orientation="Horizontal"/>
										</ItemsPanelTemplate>
									</ItemsControl.ItemsPanel>
									<ItemsControl.ItemTemplate>
										<DataTemplate DataType="{x:Type vm:NoteCardViewModel}">
											<Button Style="{StaticResource RecentNoteCardStyle}"
													Tag="{Binding}"
													Click="RecentNoteButton_Click">
												<StackPanel MinWidth="120" MaxWidth="180">
													<TextBlock Text="{Binding Document.Title}"
															   FontWeight="SemiBold"
															   FontSize="13"
															   TextTrimming="CharacterEllipsis"
															   Foreground="{DynamicResource TextColor}"/>
													<TextBlock Text="{Binding Document.LastModified, StringFormat='{}{0:dd MMM, HH:mm}'}"
															   FontSize="11"
															   Foreground="{DynamicResource TextColor}"
															   Margin="0,4,0,0"/>
												</StackPanel>
											</Button>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</ScrollViewer>
						</Border>
					</StackPanel>
				</Border>
				<!-- All Notes + FAB -->
             <Grid Grid.Row="1">
				   <ScrollViewer x:Name="NotesScrollViewer"
								 VerticalScrollBarVisibility="Auto"
								 Padding="8"
								 AllowDrop="True"
								 PreviewDragOver="NotesScrollViewer_PreviewDragOver"
								 PreviewMouseWheel="NotesScrollViewer_PreviewMouseWheel">
                        <Grid Margin="0,0,0,18">
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="Auto"/>
							</Grid.RowDefinitions>

							<Border x:Name="GroupsSectionContainer"
									Visibility="{Binding HasGroups, Converter={StaticResource BoolToVis}}"
									Margin="0,0,0,10"
									RenderTransformOrigin="0.5,0.5">
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="Grid.Row" Value="0"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsGroupsFirst}" Value="False">
												<Setter Property="Grid.Row" Value="1"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<Border.RenderTransform>
									<TranslateTransform/>
								</Border.RenderTransform>
								<StackPanel>
									<Grid Margin="10,6,10,8">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>
										<TextBlock Text="{Binding [Groups], Source={StaticResource Loc}}"
												   FontSize="14"
												   FontWeight="SemiBold"
												   Foreground="{DynamicResource TextColor}"
												   VerticalAlignment="Center"/>
                                     <Button Grid.Column="1" Width="26" Height="26" Margin="0,0,2,0" Padding="0" FontSize="12" Content="↑" Background="#EAF2FF" Foreground="#2A5BCF" BorderBrush="#BCD2FF" BorderThickness="1" Cursor="Hand" ToolTip="Move groups section up" Click="MoveGroupsUpButton_Click"/>
                                     <Button Grid.Column="2" Width="26" Height="26" Margin="0,0,4,0" Padding="0" FontSize="12" Content="↓" Background="#EAF2FF" Foreground="#2A5BCF" BorderBrush="#BCD2FF" BorderThickness="1" Cursor="Hand" ToolTip="Move groups section down" Click="MoveGroupsDownButton_Click"/>
										<Button Grid.Column="3" Width="28" Height="28" Padding="0" FontSize="15" Background="#F2F2F5" Foreground="#444" BorderBrush="#D8D8DE" BorderThickness="1" Cursor="Hand" ToolTip="Show/Hide groups" Click="ToggleGroupsSectionButton_Click">
											<Button.Style>
												<Style TargetType="Button">
													<Setter Property="Content" Value="▾"/>
													<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
													<Setter Property="RenderTransform">
														<Setter.Value><RotateTransform Angle="0"/></Setter.Value>
													</Setter>
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsGroupsSectionExpanded}" Value="False">
															<Setter Property="RenderTransform"><Setter.Value><RotateTransform Angle="-90"/></Setter.Value></Setter>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Button.Style>
										</Button>
									</Grid>
                                 <StackPanel x:Name="GroupsSectionBody">
										<ItemsControl x:Name="GroupsItemsControl" ItemsSource="{Binding NoteGroups}">
									<ItemsControl.ItemTemplate>
										<DataTemplate DataType="{x:Type vm:NoteGroupViewModel}">
											<Border Style="{StaticResource GroupCardStyle}"
                                                    Background="{Binding BackgroundBrush}"
													BorderBrush="#D9E3FF"
													BorderThickness="1"
													CornerRadius="12"
													Padding="10"
													Margin="8,0,8,10"
													AllowDrop="True"
													DragOver="GroupBorder_DragOver"
													Drop="GroupBorder_Drop">
												<Border.Tag>
													<Binding/>
												</Border.Tag>
                                                <StackPanel>
													<Grid Margin="2,0,2,8">
														<Grid.ColumnDefinitions>
															<ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
																<ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
															<ColumnDefinition Width="Auto"/>
														</Grid.ColumnDefinitions>
														<TextBlock Text="{Binding Name}"
																   FontWeight="SemiBold"
																   Foreground="#2F3A59"
																   VerticalAlignment="Center"
																   TextTrimming="CharacterEllipsis"
																   Margin="0,0,8,0"/>
                                                         <Button Grid.Column="1"
																  Width="24"
																	Height="24"
																	Padding="0"
																	FontSize="11"
																	Content="↑"
																	Background="#EEF5FF"
																	Foreground="#2A5BCF"
																	BorderBrush="#C8DAFF"
																	BorderThickness="1"
																	Cursor="Hand"
																	Margin="0,0,3,0"
																	Tag="{Binding}"
																	ToolTip="Move this group up"
																	Click="MoveSingleGroupUpButton_Click"/>
															<Button Grid.Column="2"
																  Width="24"
																	Height="24"
																	Padding="0"
																	FontSize="11"
																	Content="↓"
																	Background="#EEF5FF"
																	Foreground="#2A5BCF"
																	BorderBrush="#C8DAFF"
																	BorderThickness="1"
																	Cursor="Hand"
																	Margin="0,0,4,0"
																	Tag="{Binding}"
																	ToolTip="Move this group down"
																	Click="MoveSingleGroupDownButton_Click"/>
															<Button Grid.Column="3"
                                                              Width="28"
																Height="28"
																Padding="0"
																FontSize="13"
																Content="🎨"
																Background="Transparent"
																BorderThickness="0"
																Cursor="Hand"
																Margin="0,0,4,0"
																Tag="{Binding}"
																ToolTip="{Binding [GroupBackgroundColor], Source={StaticResource Loc}}"
																Click="GroupColorButton_Click">
															<Button.ContextMenu>
																<ContextMenu>
																	<MenuItem Header="{Binding [GroupColorDefault], Source={StaticResource Loc}}"
																		  Tag="#F8FAFF"
																		  Click="GroupColorMenuItem_Click"/>
																	<MenuItem Header="{Binding [GroupColorMint], Source={StaticResource Loc}}"
																		  Tag="#ECFEF1"
																		  Click="GroupColorMenuItem_Click"/>
																	<MenuItem Header="{Binding [GroupColorRose], Source={StaticResource Loc}}"
																		  Tag="#FFF1F2"
																		  Click="GroupColorMenuItem_Click"/>
																	<MenuItem Header="{Binding [GroupColorAmber], Source={StaticResource Loc}}"
																		  Tag="#FFFBEB"
																		  Click="GroupColorMenuItem_Click"/>
																	<MenuItem Header="{Binding [GroupColorLilac], Source={StaticResource Loc}}"
																		  Tag="#F5F3FF"
																		  Click="GroupColorMenuItem_Click"/>
																</ContextMenu>
															</Button.ContextMenu>
														</Button>
                                                         <Button Grid.Column="4"
																Width="28"
																Height="28"
																Padding="0"
																FontSize="16"
																FontWeight="Bold"
																Content="&#x22EE;"
																Background="Transparent"
																BorderThickness="0"
																Cursor="Hand"
																Tag="{Binding}"
																Click="GroupMenuButton_Click">
															<Button.ContextMenu>
																<ContextMenu>
																	<MenuItem Header="{Binding [RenameGroup], Source={StaticResource Loc}}"
																			  Click="RenameGroupMenuItem_Click"/>
																	<Separator/>
																	<MenuItem Header="{Binding [DisbandGroup], Source={StaticResource Loc}}"
																			  Click="DisbandGroupMenuItem_Click"/>
																</ContextMenu>
															</Button.ContextMenu>
														</Button>
													</Grid>
													<ItemsControl ItemsSource="{Binding Notes}">
														<ItemsControl.ItemsPanel>
															<ItemsPanelTemplate>
																<WrapPanel Orientation="Horizontal"/>
															</ItemsPanelTemplate>
														</ItemsControl.ItemsPanel>
														<ItemsControl.ItemTemplate>
															<DataTemplate DataType="{x:Type vm:NoteCardViewModel}">
																<controls:NoteCardControl/>
															</DataTemplate>
														</ItemsControl.ItemTemplate>
													</ItemsControl>
												</StackPanel>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
                                     </ItemsControl>
									</StackPanel>
								</StackPanel>
							</Border>

							<Border x:Name="UngroupedSectionContainer"
									Background="Transparent"
									AllowDrop="True"
									DragOver="UngroupedDropZone_DragOver"
									Drop="UngroupedDropZone_Drop"
									RenderTransformOrigin="0.5,0.5">
								<Border.Style>
									<Style TargetType="Border">
										<Setter Property="Grid.Row" Value="1"/>
										<Style.Triggers>
											<DataTrigger Binding="{Binding IsGroupsFirst}" Value="False">
												<Setter Property="Grid.Row" Value="0"/>
											</DataTrigger>
										</Style.Triggers>
									</Style>
								</Border.Style>
								<Border.RenderTransform>
									<TranslateTransform/>
								</Border.RenderTransform>
								<StackPanel>
									<Grid Margin="10,2,10,8">
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="*"/>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="Auto"/>
											<ColumnDefinition Width="Auto"/>
										</Grid.ColumnDefinitions>
										<TextBlock Text="{Binding [UngroupedNotes], Source={StaticResource Loc}}"
												   FontSize="14"
												   FontWeight="SemiBold"
												   Foreground="{DynamicResource TextColor}"
												   VerticalAlignment="Center"/>
                                       <Button Grid.Column="1" Width="26" Height="26" Margin="0,0,2,0" Padding="0" FontSize="12" Content="↑" Background="#FFF4EA" Foreground="#C96A1A" BorderBrush="#FFD6B3" BorderThickness="1" Cursor="Hand" ToolTip="Move ungrouped section up" Click="MoveUngroupedUpButton_Click"/>
                                     <Button Grid.Column="2" Width="26" Height="26" Margin="0,0,4,0" Padding="0" FontSize="12" Content="↓" Background="#FFF4EA" Foreground="#C96A1A" BorderBrush="#FFD6B3" BorderThickness="1" Cursor="Hand" ToolTip="Move ungrouped section down" Click="MoveUngroupedDownButton_Click"/>
										<Button Grid.Column="3" Width="28" Height="28" Padding="0" FontSize="15" Background="#F2F2F5" Foreground="#444" BorderBrush="#D8D8DE" BorderThickness="1" Cursor="Hand" ToolTip="Show/Hide ungrouped" Click="ToggleUngroupedSectionButton_Click">
											<Button.Style>
												<Style TargetType="Button">
													<Setter Property="Content" Value="▾"/>
													<Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
													<Setter Property="RenderTransform">
														<Setter.Value><RotateTransform Angle="0"/></Setter.Value>
													</Setter>
													<Style.Triggers>
														<DataTrigger Binding="{Binding IsUngroupedSectionExpanded}" Value="False">
															<Setter Property="RenderTransform"><Setter.Value><RotateTransform Angle="-90"/></Setter.Value></Setter>
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</Button.Style>
										</Button>
									</Grid>
									<StackPanel x:Name="UngroupedSectionBody">
										<ItemsControl ItemsSource="{Binding NotesView}">
										<ItemsControl.ItemsPanel>
											<ItemsPanelTemplate>
												<WrapPanel Orientation="Horizontal"/>
											</ItemsPanelTemplate>
										</ItemsControl.ItemsPanel>
										<ItemsControl.ItemTemplate>
											<DataTemplate DataType="{x:Type vm:NoteCardViewModel}">
												<controls:NoteCardControl/>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
                                     </ItemsControl>
									</StackPanel>
								</StackPanel>
							</Border>
						</Grid>
					</ScrollViewer>
					<Button Style="{StaticResource FabStyle}"
							VerticalAlignment="Bottom"
							HorizontalAlignment="Right"
							Margin="0,0,28,24"
							Content="+"
                            ToolTip="{Binding [AddNote], Source={StaticResource Loc}}"
							Command="{Binding AddNoteCommand}"/>
					<Views:SettingsPanel x:Name="SettingsPanelControl"
										 x:FieldModifier="public"
										 Visibility="Collapsed"
										 HorizontalAlignment="Center"
										 VerticalAlignment="Center"
										 Panel.ZIndex="100"/>
				</Grid>
			</Grid>
		</Grid>
	</Grid>
</Window>
