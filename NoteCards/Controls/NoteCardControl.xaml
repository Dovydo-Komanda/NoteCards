<UserControl x:Class="NoteCards.Controls.NoteCardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="220" MinHeight="140" Margin="8"
             RenderTransformOrigin="0.5,0.5"
             Opacity="0"
             AllowDrop="True"
             DataContextChanged="OnDataContextChanged"
             PreviewMouseLeftButtonDown="OnPreviewMouseLeftButtonDown"
             MouseMove="OnMouseMove"
             DragEnter="OnDragEnter"
             DragLeave="OnDragLeave"
             DragOver="OnDragOver"
             Drop="OnDrop"
             MouseEnter="OnMouseEnter" MouseLeave="OnMouseLeave">
    <UserControl.Resources>
        <Storyboard x:Key="ExitStoryboard">
            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1.0" To="0.88" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1.0" To="0.88" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseIn"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>
    <UserControl.RenderTransform>
        <ScaleTransform x:Name="CardScale" ScaleX="1" ScaleY="1"/>
    </UserControl.RenderTransform>
    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="0.88" To="1.0" Duration="0:0:0.32">
                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.25"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="0.88" To="1.0" Duration="0:0:0.32">
                        <DoubleAnimation.EasingFunction><BackEase EasingMode="EaseOut" Amplitude="0.25"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseEnter">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="CardBorder"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                     To="22" Duration="0:0:0.18">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardBorder"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                     To="0.22" Duration="0:0:0.18">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1.03" Duration="0:0:0.18">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1.03" Duration="0:0:0.18">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
        <EventTrigger RoutedEvent="MouseLeave">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="CardBorder"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.BlurRadius)"
                                     To="8" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardBorder"
                                     Storyboard.TargetProperty="(UIElement.Effect).(DropShadowEffect.Opacity)"
                                     To="0.08" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleX"
                                     To="1.0" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="CardScale"
                                     Storyboard.TargetProperty="ScaleY"
                                     To="1.0" Duration="0:0:0.2">
                        <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>
    <Border x:Name="CardBorder"
            Background="#FFFFFF"
            BorderBrush="#E4E4E7"
            BorderThickness="1"
            CornerRadius="12"
            Padding="14">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="8"
                              ShadowDepth="1" Direction="270"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border x:Name="DropGlow"
                    Background="#00000000"
                    BorderBrush="#4A6EE0"
                    BorderThickness="0"
                    CornerRadius="10"
                    Opacity="0"
                    Grid.RowSpan="2"
                    IsHitTestVisible="False"/>
            <Grid Grid.Row="0">
                <TextBlock Text="{Binding Title}"
                           FontSize="15" FontWeight="SemiBold"
                           Foreground="#1C1C1C"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,28,4"/>
                <Button x:Name="MenuButton"
                        Content="&#x22EE;"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Width="28" Height="28" Padding="0"
                        FontSize="16" FontWeight="Bold"
                        Background="Transparent" BorderThickness="0"
                        Cursor="Hand"
                        Visibility="{Binding IsMenuVisible, Converter={StaticResource BoolToVis}}"
                        Click="OnMenuButtonClick">
                    <Button.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="{Binding [Open], Source={StaticResource Loc}}" Click="OnOpenMenuClick"/>
                            <MenuItem Header="{Binding [RemoveFromGroup], Source={StaticResource Loc}}"
                                      Command="{Binding RemoveFromGroupCommand}"
                                      Visibility="{Binding IsGrouped, Converter={StaticResource BoolToVis}}"/>
                            <MenuItem Header="{Binding [Delete], Source={StaticResource Loc}}" Command="{Binding DeleteCommand}"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </Grid>
            <TextBlock Grid.Row="1"
                       Text="{Binding Content}"
                       FontSize="13" TextWrapping="Wrap"
                       MaxHeight="100"
                       TextTrimming="CharacterEllipsis"
                       Foreground="#555555"/>
        </Grid>
    </Border>
</UserControl>
