<Window x:Class="NoteCards.NoteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Note Editor" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#EBEBEF"
        Closing="NoteEditorWindow_Closing"
        xmlns:converters="clr-namespace:NoteCards.Converters">
    <Window.Resources>
        <converters:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter" />
        <Storyboard x:Key="CloseStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="14" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="16" To="0" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform Y="12"/>
        </Grid.RenderTransform>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar with Undo/Redo buttons -->
        <Border Grid.Row="0"
        Background="#F3F3F3"
        BorderBrush="#E0E0E0"
        BorderThickness="0,0,0,1"
        Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="TitleTextBox"
                 FontSize="20"
                 FontWeight="SemiBold"
                 BorderThickness="0"
                 Background="Transparent"
                 Foreground="#1C1C1C"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Center" Grid.Column="1"/>

                <StackPanel Grid.Column="0" Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
                    <!-- Undo Button -->
                    <Button Content="↶ Undo"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    Click="UndoButton_Click"/>

                    <!-- Redo Button -->
                    <Button Content="↷ Redo"
                    Padding="12,6"
                    Margin="0,0,8,0"
                    Click="RedoButton_Click"/>

                    <!-- Save Button -->
                    <Button Content="✓ Save"
                    Padding="12,6"
                    Click="SaveButton_Click"/>

                    <!-- Print Button -->
                    <Button Content="🖨 Print"
                    Padding="6,6"
                    Margin="0,0,8,0"
                    Click="PrintButton_Click"/>

                    <!-- Open file into editor -->
                    <Button x:Name="OpenFileButton"
                        Content="📂 Open"
                        Padding="6,6"
                        Margin="0,0,8,0"
                        Click="OpenFromFileButton_Click"/>

                    <!-- Search inside note (opens dialog) -->
                    <Button x:Name="SearchButton" Content="🔎 Search" Padding="6,6" Margin="0,0,4,0" Click="SearchButton_Click"/>



                <Button x:Name="Font"
                    Content="Font"
                    Padding="6,6"
                    Margin="0,0,8,0"
                    Click="FontSettings_Click"/>


				</StackPanel>
            </Grid>
        </Border>

		<!-- Font -->
		<StackPanel x:Name="FontPanel"
            Grid.Row="1"
            Orientation="Horizontal"
            Margin="16,8"
            Visibility="Collapsed">
			<TextBlock Text="Font:" VerticalAlignment="Center" Margin="0,0,6,0"/>
			<ComboBox x:Name="FontFamilyBox" Width="160" SelectionChanged="FontFamilyBox_Changed">
				<ComboBoxItem Content="Segoe UI"/>
				<ComboBoxItem Content="Arial"/>
				<ComboBoxItem Content="Times New Roman"/>
				<ComboBoxItem Content="Calibri"/>
			</ComboBox>

			<TextBlock Text="Size:" Margin="12,0,6,0" VerticalAlignment="Center"/>
			<ComboBox x:Name="FontSizeBox" Width="70" SelectionChanged="FontSizeBox_Changed">
				<ComboBoxItem Content="12"/>
				<ComboBoxItem Content="14"/>
				<ComboBoxItem Content="16"/>
				<ComboBoxItem Content="18"/>
				<ComboBoxItem Content="24"/>
			</ComboBox>

        <!-- Open file moved to top bar -->
        </StackPanel>
		
		
           <!-- Main Text Area -->
          <RichTextBox x:Name="ContentTextBox"
              Grid.Row="2"
              SelectionChanged="ContentTextBox_SelectionChanged"
              Margin="20"
              Padding="15"
              FontSize="14"
              FontFamily="Segoe UI"
              AcceptsReturn="True"
              VerticalScrollBarVisibility="{Binding EnableScrollbar, Converter={StaticResource BoolToScrollBarVisibilityConverter}}"
              BorderThickness="0"
              Background="White">
              <RichTextBox.Effect>
				<DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
			</RichTextBox.Effect>



			<!-- CONTEXT MENU -->
			<RichTextBox.ContextMenu>
				<ContextMenu>
					<MenuItem Header="Cut" Command="Cut"/>
					<MenuItem Header="Copy" Command="Copy"/>
					<MenuItem Header="Paste" Command="Paste"/>
					<Separator/>
					<MenuItem Header="Select All" Command="SelectAll"/>
				</ContextMenu>
			</RichTextBox.ContextMenu>
		</RichTextBox>
    </Grid>
</Window>
