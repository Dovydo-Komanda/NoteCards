<Window x:Class="NoteCards.NoteEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding [NoteEditorTitle], Source={StaticResource Loc}}" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#EBEBEF"
        Closing="NoteEditorWindow_Closing"
        xmlns:converters="clr-namespace:NoteCards.Converters">
    <Window.Resources>
        <converters:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter" />
        <Storyboard x:Key="CloseStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="14" Duration="0:0:0.22">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Style x:Key="EditorToolButtonBaseStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
            <Setter Property="Foreground" Value="#243047"/>
            <Setter Property="Background" Value="#F1F4FA"/>
            <Setter Property="BorderBrush" Value="#D9E1F2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#E7EDF9"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#C7D4EE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DCE6F6"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#B9CAE9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorToolIconButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorToolButtonBaseStyle}">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="EditorToolSearchInputStyle" TargetType="TextBox">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#D8E0F1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1C1C1C"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorPrimarySaveButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorToolButtonBaseStyle}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Background" Value="#3F6FE8"/>
            <Setter Property="BorderBrush" Value="#2F5CD0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SaveButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SaveButtonBorder" Property="Background" Value="#3562D8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="SaveButtonBorder" Property="Background" Value="#294CB2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorSideToolButtonStyle" TargetType="Button" BasedOn="{StaticResource EditorToolButtonBaseStyle}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="RootGrid"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="16" To="0" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <Grid x:Name="RootGrid" Opacity="0">
        <Grid.RenderTransform>
            <TranslateTransform Y="12"/>
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar with Undo/Redo buttons -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#F7F8FC"
                BorderBrush="#E2E8F5"
                BorderThickness="0,0,0,1"
                Padding="14,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Margin="0,0,14,0"
                        Background="#FFFFFF"
                        BorderBrush="#D8E0F1"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,4">
                    <TextBox x:Name="TitleTextBox"
                             FontSize="20"
                             FontWeight="SemiBold"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#1C1C1C"
                             VerticalAlignment="Center"
                             ToolTip="{Binding [NoteEditorTitle], Source={StaticResource Loc}}"/>
                </Border>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <!-- Auto-Save Indicator -->
                    <TextBlock x:Name="AutoSaveIndicator"
                            FontSize="11"
                            Foreground="#6B7280"
                            FontStyle="Italic"
                            Margin="10,0,10,0"
                            VerticalAlignment="Center"
                            Visibility="Collapsed"/>
                    <Button Content="↶"
                            Style="{StaticResource EditorToolIconButtonStyle}"
                            ToolTip="{Binding [Undo], Source={StaticResource Loc}}"
                            Click="UndoButton_Click"/>
                    <Button Content="↷"
                            Style="{StaticResource EditorToolIconButtonStyle}"
                            ToolTip="{Binding [Redo], Source={StaticResource Loc}}"
                            Click="RedoButton_Click"/>
                        <TextBox x:Name="OnlineSearchTextBox"
                             Style="{StaticResource EditorToolSearchInputStyle}"
                             ToolTip="{Binding [SearchOnlineHint], Source={StaticResource Loc}}"
                             TextChanged="OnlineSearchTextBox_TextChanged"
                             KeyDown="OnlineSearchTextBox_KeyDown"/>
                        <Button x:Name="OnlineSearchButton"
                            Content="🌐"
                            Style="{StaticResource EditorToolIconButtonStyle}"
                            ToolTip="{Binding [SearchOnline], Source={StaticResource Loc}}"
                            IsEnabled="False"
                            Click="OnlineSearchButton_Click"/>
                    <Button x:Name="SearchButton"
                            Content="🔎"
                            Style="{StaticResource EditorToolIconButtonStyle}"
                            ToolTip="{Binding [Search], Source={StaticResource Loc}}"
                            Click="SearchButton_Click"/>
                    <Button x:Name="ClearContentButton"
                            Content="🗑"
                            Style="{StaticResource EditorToolIconButtonStyle}"
                            ToolTip="{Binding [ClearContent], Source={StaticResource Loc}}"
                            Click="ClearContentButton_Click"/>
                    <Button Content="✓"
                            Style="{StaticResource EditorPrimarySaveButtonStyle}"
                            ToolTip="{Binding [Save], Source={StaticResource Loc}}"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

       <Border Grid.Row="1"
                Grid.Column="0"
                Margin="20,10,20,0"
                Padding="12,8"
                CornerRadius="10"
                Background="#FFFFFF"
                BorderBrush="#DBE3F3"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding [Tags], Source={StaticResource Loc}}"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="#425170"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="TagsTextBox"
                         Grid.Column="1"
                         BorderThickness="0"
                         Background="Transparent"
                         VerticalContentAlignment="Center"
                         Foreground="#2C3650"
                         ToolTip="{Binding [TagsHint], Source={StaticResource Loc}}"/>
            </Grid>
        </Border>

        <!-- Font -->
        <Border x:Name="FontPanel"
                Grid.Row="2"
                Grid.Column="0"
                Margin="20,10,20,0"
                Padding="12,8"
                CornerRadius="10"
                Background="#FFFFFF"
                BorderBrush="#DBE3F3"
                BorderThickness="1"
                Visibility="Collapsed">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding [FontLabel], Source={StaticResource Loc}}"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"
                           FontWeight="SemiBold"
                           Foreground="#425170"/>
                <ComboBox x:Name="FontFamilyBox" Width="160" SelectionChanged="FontFamilyBox_Changed">
                    <ComboBoxItem Content="Segoe UI"/>
                    <ComboBoxItem Content="Arial"/>
                    <ComboBoxItem Content="Times New Roman"/>
                    <ComboBoxItem Content="Calibri"/>
                </ComboBox>

                <TextBlock Text="{Binding [SizeLabel], Source={StaticResource Loc}}"
                           Margin="12,0,6,0"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="#425170"/>
                <ComboBox x:Name="FontSizeBox" Width="70" SelectionChanged="FontSizeBox_Changed">
                    <ComboBoxItem Content="12"/>
                    <ComboBoxItem Content="14"/>
                    <ComboBoxItem Content="16"/>
                    <ComboBoxItem Content="18"/>
                    <ComboBoxItem Content="24"/>
                </ComboBox>
            </StackPanel>
        </Border>
		
		
           <!-- Main Text Area -->
        <Border Grid.Row="3"
                Grid.Column="0"
                Margin="20,10,20,20"
                Padding="2"
                CornerRadius="12"
                BorderBrush="#D8E1F4"
                BorderThickness="1"
                Background="#FFFFFF">
            <Border.Effect>
                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08"/>
            </Border.Effect>
            <RichTextBox x:Name="ContentTextBox"
						 SelectionChanged="ContentTextBox_SelectionChanged"
						 PreviewMouseWheel="ContentTextBox_PreviewMouseWheel"
						 Margin="0"
						 Padding="16"
						 FontSize="14"
						 FontFamily="Segoe UI"
						 AcceptsReturn="True"
						 VerticalScrollBarVisibility="{Binding EnableScrollbar, Converter={StaticResource BoolToScrollBarVisibilityConverter}}"
						 BorderThickness="0">

                <!-- CONTEXT MENU -->
			<RichTextBox.ContextMenu>
				<ContextMenu>
				  <MenuItem Header="{Binding [Cut], Source={StaticResource Loc}}" Command="Cut"/>
					<MenuItem Header="{Binding [Copy], Source={StaticResource Loc}}" Command="Copy"/>
					<MenuItem Header="{Binding [Paste], Source={StaticResource Loc}}" Command="Paste"/>
					<Separator/>
				 <MenuItem Header="{Binding [SelectAll], Source={StaticResource Loc}}" Command="SelectAll"/>
				</ContextMenu>
			</RichTextBox.ContextMenu>

			<RichTextBox.Background>
				<SolidColorBrush Color="White"/>
			</RichTextBox.Background>
			</RichTextBox>
        </Border>
        <!-- COUNTER -->
        <Border Grid.Row="4"
        Grid.Column="0"
        Margin="20,0,20,10"
        Padding="8"
        CornerRadius="8"
        Background="#F7F8FC"
        BorderBrush="#DBE3F3"
        BorderThickness="1">

            <TextBlock x:Name="CounterText"
               Text="Words: 0 | Characters: 0 | Lines: 0"
               FontSize="12"
               Foreground="#6B7280"/>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="1"
                Grid.RowSpan="3"
                Margin="0,10,20,20"
                Padding="8"
                CornerRadius="10"
                Background="#FFFFFF"
                BorderBrush="#DBE3F3"
                BorderThickness="1"
                VerticalAlignment="Top">
            <StackPanel>
                <Button x:Name="OpenFileButton"
                        Content="📂"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="{Binding [Open], Source={StaticResource Loc}}"
                        Click="OpenFromFileButton_Click"/>
                <Button Content="🖨"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="{Binding [Print], Source={StaticResource Loc}}"
                        Click="PrintButton_Click"/>
                <Button Content="📄 Export PDF"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="{Binding [Export], Source={StaticResource Loc}}"
                        Click="ExportPdfButton_Click"/>
                <Button Content="🖼"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="{Binding [InsertImage], Source={StaticResource Loc}}"
                        Click="InsertImageButton_Click"/>
                <Separator Margin="4,0,4,8"/>
                <Button Content="↔"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="Toggle Word Wrap"
                        Click="ToggleWordWrap_Click"/>
                <Separator Margin="4,0,4,8"/>
                <Button x:Name="FontButton"
                        Content="𝑭"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="{Binding [Font], Source={StaticResource Loc}}"
                        Click="FontSettings_Click"/>
                <Separator Margin="4,0,4,8"/>
                <Button Content="🔍+"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="Zoom In"
                        Click="ZoomInButton_Click"/>
                <Button Content="🔍-"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="Zoom Out"
                        Click="ZoomOutButton_Click"/>
                <Button Content="1:1"
                        Style="{StaticResource EditorSideToolButtonStyle}"
                        ToolTip="Reset Zoom"
                        Click="ZoomResetButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
