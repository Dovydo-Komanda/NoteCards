<Window x:Class="NoteCards.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding [About], Source={StaticResource Loc}}"
        Width="360"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Closing="AboutWindow_Closing"
        Background="#FAFAFA">
    <Window.Resources>
        <Style x:Key="AuthorLineStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#3A3A3A"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        </Style>
        <Storyboard x:Key="CloseStoryboard">
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ContentPanel"
                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                             From="0" To="8" Duration="0:0:0.18">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>
    <Window.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="ContentPanel"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ContentPanel"
                                     Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                     From="12" To="0" Duration="0:0:0.28">
                        <DoubleAnimation.EasingFunction>
                            <QuadraticEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>
    <StackPanel x:Name="ContentPanel" Opacity="0">
        <StackPanel.RenderTransform>
            <TranslateTransform Y="12"/>
        </StackPanel.RenderTransform>

        <!-- Gradient header -->
        <Border BorderBrush="#E0E0E8" BorderThickness="0,0,0,1" Padding="32,28,32,22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#EEF2FF" Offset="0"/>
                    <GradientStop Color="#F3F4F6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel HorizontalAlignment="Center">
                <Border CornerRadius="16" Width="60" Height="60"
                        HorizontalAlignment="Center" Margin="0,0,0,14">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6B8FF8" Offset="0"/>
                            <GradientStop Color="#4A6EE0" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.Effect>
                        <DropShadowEffect Color="#5B7FEE" Opacity="0.45"
                                          BlurRadius="14" ShadowDepth="3" Direction="270"/>
                    </Border.Effect>
                    <TextBlock Text="📝" FontSize="26"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="NoteCards"
                           FontSize="22" FontWeight="SemiBold"
                           Foreground="#1C1C1C"
                           HorizontalAlignment="Center"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                <TextBlock Text="v1.0.0_alpha-1"
                           FontSize="11"
                           Foreground="#9CA3AF"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"
                           FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Margin="32,20,32,28">
            <TextBlock Text="{Binding [AboutDescription], Source={StaticResource Loc}, Mode=OneWay}"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       FontSize="13"
                       Foreground="#555555"
                       Margin="0,0,0,18"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

            <Separator Background="#E8E8EB" Margin="0,0,0,16"/>

            <TextBlock Text="{Binding [Authors], Source={StaticResource Loc}}"
                       FontSize="10" FontWeight="Bold"
                       Foreground="#C0C0C8"
                       Margin="0,0,0,6"
                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

            <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Mantas Gaižutis"/>
            <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Jaunius Pigaga"/>
            <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Rapolas Turauskas"/>
            <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Deividas Kepenis"/>
            <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Gustas Valaika"/>
            <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Mantas Brūžė"/>

            <Button Content="{Binding [Close], Source={StaticResource Loc}}"
                    HorizontalAlignment="Center"
                    Padding="40,9"
                    FontSize="13"
                    Margin="0,24,0,0"
                    Cursor="Hand"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
