<UserControl x:Class="NoteCards.Views.AboutPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="960">
    <UserControl.Resources>
        <Style x:Key="AuthorLineStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Opacity" Value="0.86"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI, sans-serif"/>
        </Style>

        <Style x:Key="AboutCloseIconButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#DDE4F3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="#EAF0FD"/>
                                <Setter TargetName="CloseButtonBorder" Property="BorderBrush" Value="#C9D7F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="#DCE7FB"/>
                                <Setter TargetName="CloseButtonBorder" Property="BorderBrush" Value="#B8CAF2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="OverlayRoot" Background="#66000000" MouseDown="OverlayRoot_MouseDown">
        <Border x:Name="PanelCard"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="16"
                Width="500"
                MaxWidth="500"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.20" BlurRadius="24" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Margin="20,18,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding [About], Source={StaticResource Loc}}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource AboutCloseIconButtonStyle}"
                            Content="✕"
                            Click="CloseButton_Click"/>
                </Grid>

                <StackPanel Grid.Row="1" x:Name="ContentPanel" Margin="20,12,20,18">
                    <Border BorderBrush="{DynamicResource BorderColor}" BorderThickness="0,0,0,1" Padding="18,16,18,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EEF2FF" Offset="0"/>
                                <GradientStop Color="#F3F4F6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel HorizontalAlignment="Center">
                            <Border CornerRadius="14"
                                    Width="54"
                                    Height="54"
                                    Background="#FFFFFF"
                                    BorderBrush="#DCE4F5"
                                    BorderThickness="1"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,10">
                                <Border.Effect>
                                    <DropShadowEffect Color="#5B7FEE" Opacity="0.24" BlurRadius="12" ShadowDepth="2" Direction="270"/>
                                </Border.Effect>
                                <Image Source="/NoteCards;component/logo.ico"
                                       Width="30"
                                       Height="30"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="NoteCards"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextColor}"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                            <TextBlock Text="v1.0.0_alpha-1"
                                       FontSize="11"
                                       Foreground="#9CA3AF"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"
                                       FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="4,12,4,0">
                        <TextBlock Text="{Binding [AboutDescription], Source={StaticResource Loc}, Mode=OneWay}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextColor}"
                                   Opacity="0.86"
                                   Margin="0,0,0,10"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                        <Separator Background="{DynamicResource BorderColor}" Margin="0,0,0,10"/>

                        <TextBlock Text="{Binding [Authors], Source={StaticResource Loc}}"
                                   FontSize="10"
                                   FontWeight="Bold"
                                   Foreground="#9CA3AF"
                                   Margin="0,0,0,6"
                                   FontFamily="Segoe UI Variable, Segoe UI, sans-serif"/>

                        <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Mantas Gaižutis"/>
                        <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Jaunius Pigaga"/>
                        <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Rapolas Turauskas"/>
                        <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Deividas Kepenis"/>
                        <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Gustas Valaika"/>
                        <TextBlock Style="{StaticResource AuthorLineStyle}" Text="Mantas Brūžė"/>

                        <Button Content="{Binding [Close], Source={StaticResource Loc}}"
                                Style="{StaticResource DialogSecondaryButtonStyle}"
                                HorizontalAlignment="Center"
                                Padding="28,8"
                                Margin="0,14,0,0"
                                Click="CloseButton_Click"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
