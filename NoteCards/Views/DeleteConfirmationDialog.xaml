<Window x:Class="NoteCards.Views.DeleteConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DeleteConfirmation"
        Height="280"
        Width="480"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">

    <Grid Background="Transparent">
        <Border Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="32,28"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxWidth="420">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.25" BlurRadius="32" ShadowDepth="4"/>
            </Border.Effect>
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Icon and Title -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Warning Icon -->
                    <Border Grid.Column="0"
                            Width="48"
                            Height="48"
                            Background="#FFF3F4"
                            CornerRadius="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top">
                        <TextBlock Text="⚠"
                                   FontSize="24"
                                   Foreground="#DC2626"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title -->
                    <StackPanel Grid.Column="1" Margin="16,4,0,0">
                        <TextBlock Text="{Binding [ConfirmDelete], Source={StaticResource Loc}}"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>

                <!-- Message -->
                <TextBlock Grid.Row="1"
                           Text="{Binding [DeleteNoteConfirmation], Source={StaticResource Loc}}"
                           FontSize="14"
                           Foreground="{DynamicResource TextColor}"
                           Opacity="0.85"
                           TextWrapping="Wrap"
                           Margin="0,0,0,24"
                           LineHeight="20"/>

                <!-- Buttons -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="{Binding [Cancel], Source={StaticResource Loc}}"
                            Style="{StaticResource DialogSecondaryButtonStyle}"
                            Padding="20,10"
                            MinWidth="110"
                            Click="CancelButton_Click"/>

                    <Button Content="{Binding [Confirm], Source={StaticResource Loc}}"
                            Style="{StaticResource DialogDangerButtonStyle}"
                            Padding="20,10"
                            MinWidth="110"
                            Margin="12,0,0,0"
                            Click="ConfirmButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>