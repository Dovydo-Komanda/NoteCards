<Window x:Class="NoteCards.Views.SearchReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Find / Replace" Height="180" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="Find:" VerticalAlignment="Center" Width="60"/>
            <TextBox x:Name="SearchBox" Width="320" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="Replace:" VerticalAlignment="Center" Width="60"/>
            <TextBox x:Name="ReplaceBox" Width="320" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="FindNextBtn" Content="Find Next" Style="{StaticResource DialogSecondaryButtonStyle}" MinWidth="100" Padding="14,7" Margin="0,0,8,0" Click="FindNextBtn_Click" />
            <Button x:Name="ReplaceNextBtn" Content="Replace Next" Style="{StaticResource DialogPrimaryButtonStyle}" MinWidth="108" Padding="14,7" Margin="0,0,8,0" Click="ReplaceNextBtn_Click" />
            <Button Content="Close" Style="{StaticResource DialogSecondaryButtonStyle}" MinWidth="84" Padding="14,7" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
