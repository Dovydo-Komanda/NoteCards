<UserControl x:Class="NoteCards.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">
    <Border Background="#FFFFFF" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="12" Padding="24">
        <StackPanel>
            <TextBlock Text="{Binding [Settings], Source={StaticResource Loc}}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
            <TextBlock Text="{Binding [Language], Source={StaticResource Loc}}" FontSize="14" Margin="0,8,0,0"/>
            <ComboBox Width="160"
                      Margin="0,4,0,0"
                      SelectedValuePath="Tag"
                      SelectedValue="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Tag="en" Content="{Binding [LanguageEnglish], Source={StaticResource Loc}}"/>
                <ComboBoxItem Tag="lt" Content="{Binding [LanguageLithuanian], Source={StaticResource Loc}}"/>
            </ComboBox>
            <!-- Scrollbar Settings -->
            <TextBlock Text="{Binding [Scrollbar], Source={StaticResource Loc}}" FontSize="14" Margin="0,8,0,0"/>
            <CheckBox x:Name="EnableScrollbarCheckBox"
                      Content="{Binding [EnableScrollbar], Source={StaticResource Loc}}"
                      Margin="0,4,0,0"
                      IsChecked="{Binding EnableScrollbar, Mode=TwoWay}"/>
            <!-- Example settings UI -->
            <TextBlock Text="{Binding [Theme], Source={StaticResource Loc}}" FontSize="14" Margin="0,8,0,0"/>
            <ComboBox Width="160"
                      Margin="0,4,0,0"
                      SelectedValuePath="Tag"
                      SelectedValue="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBoxItem Tag="Light" Content="{Binding [ThemeLight], Source={StaticResource Loc}}"/>
                <ComboBoxItem Tag="Dark" Content="{Binding [ThemeDark], Source={StaticResource Loc}}"/>
            </ComboBox>
            <Button Content="{Binding [CheckForUpdates], Source={StaticResource Loc}}"
                    Margin="0,12,0,0"
                    Width="160"
                    Click="CheckUpdates_Click"/>
            <Button Content="{Binding [Close], Source={StaticResource Loc}}" HorizontalAlignment="Right" Margin="0,24,0,0" Width="80" Click="CloseButton_Click"/>
        </StackPanel>
    </Border>
</UserControl>
