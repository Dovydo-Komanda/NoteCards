<UserControl x:Class="NoteCards.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400">
    <Border Background="#FFFFFF" BorderBrush="#D8D8D8" BorderThickness="1" CornerRadius="12" Padding="24">
        <StackPanel>
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>
            <!-- Example settings UI -->
            <TextBlock Text="Theme:" FontSize="14" Margin="0,8,0,0"/>
            <ComboBox Width="160"
                      Margin="0,4,0,0"
                      SelectionChanged="ThemeChanged">
                <ComboBoxItem Content="Light"/>
                <ComboBoxItem Content="Dark"/>
            </ComboBox>
            <Button Content="Close" HorizontalAlignment="Right" Margin="0,24,0,0" Width="80" Click="CloseButton_Click"/>
        </StackPanel>
    </Border>
</UserControl>
