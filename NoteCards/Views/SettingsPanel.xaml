<UserControl x:Class="NoteCards.Views.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="960">
    <UserControl.Resources>
        <Style x:Key="SettingsCloseIconButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextColor}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#DDE4F3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="CloseButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="#EAF0FD"/>
                                <Setter TargetName="CloseButtonBorder" Property="BorderBrush" Value="#C9D7F5"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="CloseButtonBorder" Property="Background" Value="#DCE7FB"/>
                                <Setter TargetName="CloseButtonBorder" Property="BorderBrush" Value="#B8CAF2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid x:Name="OverlayRoot" Background="#66000000" MouseDown="OverlayRoot_MouseDown">
        <Border x:Name="PanelCard"
                Background="{DynamicResource CardBackground}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="24"
                Width="560"
                MaxWidth="560"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.20" BlurRadius="24" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="{Binding [Settings], Source={StaticResource Loc}}"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextColor}"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource SettingsCloseIconButtonStyle}"
                            Content="✕"
                            Click="CloseButton_Click"/>
                </Grid>

                <Border Grid.Row="1"
                        Margin="0,18,0,0"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="22"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding [Language], Source={StaticResource Loc}}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextColor}"/>
                            <ComboBox Margin="0,8,0,0"
                                      MinWidth="180"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding SelectedLanguage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Tag="en" Content="{Binding [LanguageEnglish], Source={StaticResource Loc}}"/>
                                <ComboBoxItem Tag="lt" Content="{Binding [LanguageLithuanian], Source={StaticResource Loc}}"/>
                            </ComboBox>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Width="1"
                                Margin="10,0"
                                Background="{DynamicResource BorderColor}"/>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{Binding [Theme], Source={StaticResource Loc}}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextColor}"/>
                            <ComboBox Margin="0,8,0,0"
                                      MinWidth="180"
                                      SelectedValuePath="Tag"
                                      SelectedValue="{Binding SelectedTheme, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBoxItem Tag="Light" Content="{Binding [ThemeLight], Source={StaticResource Loc}}"/>
                                <ComboBoxItem Tag="Dark" Content="{Binding [ThemeDark], Source={StaticResource Loc}}"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Scrollbar and Auto-Save Settings -->
                <Border Grid.Row="2"
        Margin="0,14,0,0"
        Background="{DynamicResource SidebarBackground}"
        BorderBrush="{DynamicResource BorderColor}"
        BorderThickness="1"
        CornerRadius="12"
        Padding="16,12">
                    <StackPanel>
                        <!-- Scrollbar Setting -->
                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{Binding [Scrollbar], Source={StaticResource Loc}}"
                       VerticalAlignment="Center"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextColor}"/>
                            <CheckBox Grid.Column="1"
                      x:Name="EnableScrollbarCheckBox"
                      Content="{Binding [EnableScrollbar], Source={StaticResource Loc}}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      IsChecked="{Binding EnableScrollbar, Mode=TwoWay}"/>
                        </Grid>

                        <Border Height="1" 
                Background="{DynamicResource BorderColor}" 
                Margin="0,0,0,12"/>

                        <!-- Auto-Save Setting -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding [AutoSave], Source={StaticResource Loc}}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>

                            <CheckBox Grid.Column="1"
                      x:Name="EnableAutoSaveCheckBox"
                      Content="{Binding [EnableAutoSave], Source={StaticResource Loc}}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      IsChecked="True"
                      Checked="EnableAutoSaveCheckBox_Checked"
                      Unchecked="EnableAutoSaveCheckBox_Unchecked"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Activity Summary Settings -->
                <Border Grid.Row="3"
                        Margin="0,14,0,0"
                        Background="{DynamicResource SidebarBackground}"
                        BorderBrush="{DynamicResource BorderColor}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,12">
                    <StackPanel>
                        <TextBlock Text="{Binding UserActivitySummaryTitle}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextColor}"
                                   Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="{Binding StatsTotalNotes}" Foreground="{DynamicResource TextColor}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding StatsWordsTyped}" Foreground="{DynamicResource TextColor}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding StatsCharactersTyped}" Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding StatsTimeSpent}" Foreground="{DynamicResource TextColor}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding StatsLastActive}" Foreground="{DynamicResource TextColor}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Grid.Row="4" Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Content="{Binding [CheckForUpdates], Source={StaticResource Loc}}"
                            Style="{StaticResource DialogSecondaryButtonStyle}"
                            Padding="14,8"
                            MinWidth="190"
                            HorizontalAlignment="Left"
                            Click="CheckUpdates_Click"/>

                    <Button Grid.Column="1"
                            Style="{StaticResource DialogPrimaryButtonStyle}"
                            Content="{Binding [Close], Source={StaticResource Loc}}"
                            Margin="10,0,0,0"
                            MinWidth="100"
                            Padding="14,8"
                            Click="CloseButton_Click"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
