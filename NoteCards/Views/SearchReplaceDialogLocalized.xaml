<Window x:Class="NoteCards.Views.SearchReplaceDialogLocalized"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding [FindReplaceTitle], Source={StaticResource Loc}}" Height="180" Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
            <TextBlock Text="{Binding [FindLabel], Source={StaticResource Loc}}" VerticalAlignment="Center" Width="60"/>
            <TextBox x:Name="SearchBox" Width="320" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,8">
            <TextBlock Text="{Binding [ReplaceLabel], Source={StaticResource Loc}}" VerticalAlignment="Center" Width="60"/>
            <TextBox x:Name="ReplaceBox" Width="320" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="FindNextBtn" Content="{Binding [FindNext], Source={StaticResource Loc}}" Width="100" Margin="0,0,8,0" Click="FindNextBtn_Click" />
            <Button x:Name="ReplaceNextBtn" Content="{Binding [ReplaceNext], Source={StaticResource Loc}}" Width="100" Margin="0,0,8,0" Click="ReplaceNextBtn_Click" />
            <Button Content="{Binding [Close], Source={StaticResource Loc}}" Width="80" Click="Close_Click" />
        </StackPanel>
    </Grid>
</Window>
