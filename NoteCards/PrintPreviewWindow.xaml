<Window x:Class="NoteCards.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Preview" 
        Height="700" Width="900"
        WindowStartupLocation="CenterOwner"
        Background="#EBEBEF">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="#F3F3F3"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="🖨 Print"
                        Padding="16,6"
                        Margin="0,0,8,0"
                        Click="PrintButton_Click"/>
                <Button Content="Close"
                        Padding="16,6"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Preview Area -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Padding="20"
                      Background="#CCCCCC">
            <Border x:Name="PreviewPage"
                    Background="White"
                    Width="794" Height="1123"
                    Padding="60"
                    Margin="0,0,0,20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Title -->
                    <TextBlock x:Name="PreviewTitle"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1C1C1C"
                               Margin="0,0,0,20"
                               TextWrapping="Wrap"/>

                    <!-- Content -->
                    <TextBlock x:Name="PreviewContent"
                               FontSize="12"
                               Foreground="#333333"
                               TextWrapping="Wrap"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Window>